# -*-Tcl-*-
# 11-package-lifecycle.test — Package require/forget lifecycle test
#
# Verifies that tbcx can be required, forgotten, and re-required
# without errors.  Intentionally does not pre-load tbcx at file scope.

package require tcltest 2.5
namespace import ::tcltest::*

test pkg.1 {package lifecycle: require -> forget -> require} -body {
    set v1 [package require tbcx]
    package forget tbcx
    # Require again after forgetting; should succeed (commands may already exist)
    set v2 [package require tbcx]
    expr {$v1 eq $v2}
} -result 1

cleanupTests
