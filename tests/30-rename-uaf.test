# -*- tcl -*-
# 30-rename-uaf.test — renaming a tbcx-shimmed command must restore the original
# handlers in-place while the Command struct is still reachable via the old name.
# A Command struct survives a rename (unlike a delete), so ProcCmdDeleteTrace /
# OOShimDefineCmdTrace / OOShimObjdefCmdTrace / ApplyCmdDeleteTrace must, on
# TCL_TRACE_RENAME, restore the Command's objProc2/clientData rather than only
# nulling the cached Command*.  Otherwise the renamed command stays wired to
# CmdProcShim / CmdOOShim / CmdApplyShim with client data pointing at the freed
# ProcShim / OOShim / ApplyShim, and invoking it after load dereferences freed
# memory.

package require tcltest
namespace import ::tcltest::*

package require tbcx

test uaf.1 {rename proc during load, then use renamed command post-load} -setup {
    set in  [makeFile {
        proc cheerful {} { return "hello" }
        cheerful
        rename proc myproc
        myproc after_rename {} { return "after" }
    } uaf.1-in.tcl]
    set out [makeFile "" uaf.1-out.tbcx]
} -body {
    tbcx::save $in $out
    tbcx::load $out
    # Post-load: proc has been renamed to myproc.  Before the fix, this
    # call would UAF.  After the fix, the shim has been restored during
    # the rename, so myproc now behaves as vanilla [proc].
    myproc later_proc {} { return "done" }
    later_proc
} -result "done" -cleanup {
    if {[info commands myproc] ne ""} { rename myproc proc }
    removeFile $in
    removeFile $out
}

test uaf.2 {rename oo::define during load, then use renamed command post-load} -setup {
    set in  [makeFile {
        oo::class create Greeter { method greet {} { return "hi" } }
        [Greeter new] greet
        rename oo::define mydef
    } uaf.2-in.tcl]
    set out [makeFile "" uaf.2-out.tbcx]
} -body {
    tbcx::save $in $out
    tbcx::load $out
    # Post-load, mydef must behave as vanilla oo::define
    oo::class create X
    mydef X { method m {} { return "xyz" } }
    [X new] m
} -result "xyz" -cleanup {
    if {[info commands mydef] ne ""} { rename mydef oo::define }
    catch { X destroy }
    catch { Greeter destroy }
    removeFile $in
    removeFile $out
}

test uaf.3 {rename apply during load does not poison the interp} -setup {
    set in  [makeFile {
        # Force the apply shim install path via a registered lambda
        set f [apply {{x} { expr {$x * 2} }} 21]
        # Then rename apply
        rename apply myapply
    } uaf.3-in.tcl]
    set out [makeFile "" uaf.3-out.tbcx]
} -body {
    tbcx::save $in $out
    tbcx::load $out
    # myapply should work as vanilla apply
    myapply {{y} { expr {$y + 1} }} 10
} -result "11" -cleanup {
    if {[info commands myapply] ne ""} { rename myapply apply }
    removeFile $in
    removeFile $out
}

cleanupTests
