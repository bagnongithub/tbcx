# -*-Tcl-*-
package require tbcx
package require tcltest 2.5
namespace import ::tcltest::*

test oo.1 {oo: instance method} -body {
    set in  [makeFile {
        oo::class create C
        oo::define C method m {} {return ok}
        set o [C new]
        return [$o m]
    } oo.1-in.tcl]
    set out [makeFile "" oo.1-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result ok

test oo.2 {oo: constructor passes args} -body {
    set in  [makeFile {
        oo::class create D
        oo::define D constructor {x} {set ::ctor $x}
        set o [D new hello]
        return $::ctor
    } oo.2-in.tcl]
    set out [makeFile "" oo.2-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result hello

# ---- NEW TESTS ----

# Multiple methods on one class
test oo.3 {oo: multiple methods} -body {
    set in  [makeFile {
        oo::class create Calc
        oo::define Calc {
            method add {a b} {return [expr {$a + $b}]}
            method mul {a b} {return [expr {$a * $b}]}
            method neg {a}   {return [expr {-$a}]}
        }
        set c [Calc new]
        return [list [$c add 3 4] [$c mul 3 4] [$c neg 5]]
    } oo.3-in.tcl]
    set out [makeFile "" oo.3-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {7 12 -5}

# Constructor with instance variable
test oo.4 {oo: constructor with instance var} -body {
    set in  [makeFile {
        oo::class create Named
        oo::define Named {
            constructor {n} {my variable name; set name $n}
            method getname {} {my variable name; return $name}
        }
        set o [Named new Alice]
        return [$o getname]
    } oo.4-in.tcl]
    set out [makeFile "" oo.4-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result Alice

# Destructor
test oo.5 {oo: destructor runs} -body {
    set in  [makeFile {
        oo::class create Tracked
        oo::define Tracked {
            constructor {} {set ::track created}
            destructor {set ::track destroyed}
        }
        set o [Tracked new]
        set r1 $::track
        $o destroy
        return [list $r1 $::track]
    } oo.5-in.tcl]
    set out [makeFile "" oo.5-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {created destroyed}

# Inheritance: superclass
test oo.6 {oo: superclass} -body {
    set in  [makeFile {
        oo::class create Base
        oo::define Base method greet {} {return "hello from Base"}
        oo::class create Child {superclass Base}
        oo::define Child method who {} {return "I am Child"}
        set o [Child new]
        return [list [$o greet] [$o who]]
    } oo.6-in.tcl]
    set out [makeFile "" oo.6-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{hello from Base} {I am Child}}

# Method override
test oo.7 {oo: method override} -body {
    set in  [makeFile {
        oo::class create Animal
        oo::define Animal method speak {} {return "..."}
        oo::class create Dog {superclass Animal}
        oo::define Dog method speak {} {return "woof"}
        oo::class create Cat {superclass Animal}
        oo::define Cat method speak {} {return "meow"}
        set d [Dog new]
        set c [Cat new]
        return [list [$d speak] [$c speak]]
    } oo.7-in.tcl]
    set out [makeFile "" oo.7-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {woof meow}

# Method with arguments
test oo.8 {oo: method with multiple args} -body {
    set in  [makeFile {
        oo::class create Point
        oo::define Point {
            constructor {ax ay} {my variable x y; set x $ax; set y $ay}
            method distto {ox oy} {
                my variable x y
                return [expr {sqrt(($x-$ox)**2 + ($y-$oy)**2)}]
            }
        }
        set p [Point new 3.0 4.0]
        return [expr {int([$p distto 0.0 0.0])}]
    } oo.8-in.tcl]
    set out [makeFile "" oo.8-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 5

# oo::define with method block (multi-method in block)
test oo.9 {oo: define block with multiple methods} -body {
    set in  [makeFile {
        oo::class create Stack
        oo::define Stack {
            constructor {} {my variable data; set data {}}
            method push {val} {my variable data; lappend data $val; return}
            method pop {} {
                my variable data
                set val [lindex $data end]
                set data [lrange $data 0 end-1]
                return $val
            }
            method size {} {my variable data; return [llength $data]}
        }
        set s [Stack new]
        $s push a
        $s push b
        $s push c
        set p [$s pop]
        return [list $p [$s size]]
    } oo.9-in.tcl]
    set out [makeFile "" oo.9-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {c 2}

# Multiple classes in one script
test oo.10 {oo: multiple classes} -body {
    set in  [makeFile {
        oo::class create A
        oo::define A method who {} {return A}
        oo::class create B
        oo::define B method who {} {return B}
        set a [A new]
        set b [B new]
        return [list [$a who] [$b who]]
    } oo.10-in.tcl]
    set out [makeFile "" oo.10-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {A B}

# Constructor with default args
test oo.11 {oo: constructor default args} -body {
    set in  [makeFile {
        oo::class create Widget
        oo::define Widget {
            constructor {{l default}} {my variable label; set label $l}
            method getlabel {} {my variable label; return $label}
        }
        set w1 [Widget new]
        set w2 [Widget new custom]
        return [list [$w1 getlabel] [$w2 getlabel]]
    } oo.11-in.tcl]
    set out [makeFile "" oo.11-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {default custom}

# Method calling another method via self
test oo.12 {oo: method calling method via my} -body {
    set in  [makeFile {
        oo::class create Counter
        oo::define Counter {
            constructor {} {my variable n; set n 0}
            method incr {} {my variable n; incr n; return $n}
            method incr3 {} {
                my incr; my incr; my incr
            }
            method val {} {my variable n; return $n}
        }
        set c [Counter new]
        $c incr3
        return [$c val]
    } oo.12-in.tcl]
    set out [makeFile "" oo.12-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 3

# OO with exception handling in method
test oo.13 {oo: exception in method} -body {
    set in  [makeFile {
        oo::class create Safe
        oo::define Safe method div {a b} {
            try {
                return [expr {$a / $b}]
            } on error {} {
                return Inf
            }
        }
        set s [Safe new]
        return [list [$s div 10 2] [$s div 10 0]]
    } oo.13-in.tcl]
    set out [makeFile "" oo.13-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {5 Inf}

# ---- Advanced OO features (Tcl 9.1) ----

# classmethod
test oo.14 {oo: classmethod} -body {
    set out [makeFile "" oo.14-out.tbcx]
    tbcx::save {
        oo::class create Factory
        oo::define Factory {
            classmethod kind {} { return "Factory" }
            method produce {} { return "item" }
        }
        set o [Factory new]
        return [list [Factory kind] [$o produce]]
    } $out
    tbcx::load $out
} -result {Factory item}

# private method
test oo.15 {oo: private method} -body {
    set out [makeFile "" oo.15-out.tbcx]
    tbcx::save {
        oo::class create Secret
        oo::define Secret {
            method public {} { return [my helper] }
            private method helper {} { return "secret-data" }
        }
        set s [Secret new]
        return [$s public]
    } $out
    tbcx::load $out
} -result secret-data

# forward
test oo.16 {oo: method forward} -body {
    set out [makeFile "" oo.16-out.tbcx]
    tbcx::save {
        oo::class create Wrapper
        oo::define Wrapper {
            constructor {} { my variable buf; set buf {} }
            forward len string length
            method store {s} { my variable buf; set buf $s }
            method size {} { my variable buf; my len $buf }
        }
        set w [Wrapper new]
        $w store "hello"
        return [$w size]
    } $out
    tbcx::load $out
} -result 5

# filter
test oo.17 {oo: method filter} -body {
    set out [makeFile "" oo.17-out.tbcx]
    tbcx::save {
        oo::class create Logged
        oo::define Logged {
            variable log
            constructor {} { set log {} }
            method logfilter {args} {
                lappend log [self target]
                next {*}$args
            }
            method getlog {} { return $log }
            method greet {} { return "hi" }
            filter logfilter
        }
        set o [Logged new]
        $o greet
        $o greet
        return [llength [$o getlog]]
    } $out
    tbcx::load $out
} -result 3

# mixin
test oo.18 {oo: mixin} -body {
    set out [makeFile "" oo.18-out.tbcx]
    tbcx::save {
        oo::class create Describable
        oo::define Describable method describe {} { return "I am [self class]" }
        oo::class create Thing
        oo::define Thing method name {} { return "thing" }
        oo::define Thing mixin Describable
        set t [Thing new]
        return [list [$t name] [$t describe]]
    } $out
    tbcx::load $out
} -result {thing {I am ::Describable}}

# oo::objdefine
test oo.19 {oo: objdefine per-object method} -body {
    set out [makeFile "" oo.19-out.tbcx]
    tbcx::save {
        oo::class create Oo19Base
        oo::define Oo19Base method shared {} { return "shared" }
        set o [Oo19Base new]
        oo::objdefine $o method special {} { return "per-object" }
        return [list [$o shared] [$o special]]
    } $out
    tbcx::load $out
} -result {shared per-object}

# oo::copy
test oo.20 {oo: copy object} -body {
    set out [makeFile "" oo.20-out.tbcx]
    tbcx::save {
        oo::class create Stateful
        oo::define Stateful {
            constructor {v} { my variable val; set val $v }
            method get {} { my variable val; return $val }
        }
        set a [Stateful new 42]
        set b [oo::copy $a]
        return [list [$a get] [$b get]]
    } $out
    tbcx::load $out
} -result {42 42}

# oo::abstract
test oo.21 {oo: abstract class} -body {
    set out [makeFile "" oo.21-out.tbcx]
    tbcx::save {
        oo::abstract create Shape
        oo::define Shape method area {} { error "abstract" }
        oo::class create Circle {superclass Shape}
        oo::define Circle {
            constructor {r} { my variable radius; set radius $r }
            method area {} { my variable radius; expr {3.14159 * $radius * $radius} }
        }
        set c [Circle new 1.0]
        return [expr {int([$c area] * 100)}]
    } $out
    tbcx::load $out
} -result 314

# oo::singleton
test oo.22 {oo: singleton class} -body {
    set out [makeFile "" oo.22-out.tbcx]
    tbcx::save {
        oo::singleton create Registry
        oo::define Registry {
            constructor {} { my variable data; set data {} }
            method add {k v} { my variable data; dict set data $k $v }
            method get {k} { my variable data; dict get $data $k }
        }
        set a [Registry new]
        $a add color blue
        set b [Registry new]
        return [$b get color]
    } $out
    tbcx::load $out
} -result blue

# deletemethod
test oo.23 {oo: deletemethod} -body {
    set out [makeFile "" oo.23-out.tbcx]
    tbcx::save {
        oo::class create HasExtra
        oo::define HasExtra {
            method keep {} { return "kept" }
            method temp {} { return "temporary" }
        }
        oo::define HasExtra deletemethod temp
        set o [HasExtra new]
        set kept [$o keep]
        set rc [catch {$o temp} msg]
        return [list $kept $rc]
    } $out
    tbcx::load $out
} -result {kept 1}

# renamemethod
test oo.24 {oo: renamemethod} -body {
    set out [makeFile "" oo.24-out.tbcx]
    tbcx::save {
        oo::class create Oo24Named
        oo::define Oo24Named method original {} { return "content" }
        oo::define Oo24Named renamemethod original aliased
        set o [Oo24Named new]
        return [$o aliased]
    } $out
    tbcx::load $out
} -result content

# unexport
test oo.25 {oo: unexport method} -body {
    set out [makeFile "" oo.25-out.tbcx]
    tbcx::save {
        oo::class create Guarded
        oo::define Guarded {
            method internal {} { return "internal" }
            method api {} { return [my internal] }
        }
        oo::define Guarded unexport internal
        set o [Guarded new]
        set api [$o api]
        set rc [catch {$o internal} msg]
        return [list $api $rc]
    } $out
    tbcx::load $out
} -result {internal 1}

# metaclass
test oo.26 {oo: metaclass} -body {
    set out [makeFile "" oo.26-out.tbcx]
    tbcx::save {
        oo::class create Oo26Meta {
            superclass oo::class
            self method create {name args} {
                set cls [next $name {*}$args]
                return $cls
            }
        }
        Oo26Meta create Oo26Animal {
            method speak {} { return "..." }
        }
        set a [Oo26Animal new]
        return [$a speak]
    } $out
    tbcx::load $out
} -result ...

# next in constructor chain
test oo.27 {oo: constructor with next chaining} -body {
    set out [makeFile "" oo.27-out.tbcx]
    tbcx::save {
        oo::class create Oo27A
        oo::define Oo27A constructor {} { append ::trace "A" }
        oo::class create Oo27B {superclass Oo27A}
        oo::define Oo27B constructor {} { set ::trace "B+"; next }
        set ::trace ""
        set o [Oo27B new]
        return $::trace
    } $out
    tbcx::load $out
} -result B+A

# Diamond inheritance
test oo.28 {oo: diamond inheritance with next} -body {
    set out [makeFile "" oo.28-out.tbcx]
    tbcx::save {
        oo::class create Top
        oo::define Top method who {} { return "Top" }
        oo::class create Left {superclass Top}
        oo::define Left method who {} { return "Left+[next]" }
        oo::class create Right {superclass Top}
        oo::define Right method who {} { return "Right+[next]" }
        oo::class create Bottom {superclass Left Right}
        oo::define Bottom method who {} { return "Bottom+[next]" }
        set o [Bottom new]
        return [$o who]
    } $out
    tbcx::load $out
} -result Bottom+Left+Right+Top



cleanupTests
