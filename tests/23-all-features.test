# -*-Tcl-*-
# 23-all-features.test — Self-contained Tcl 9.1 language feature coverage
#
# Every test builds a script using braced {append}, saves/loads it via
# tbcx, and verifies internal assertions pass. No double-quote escaping.

package require tbcx
package require tcltest 2.5
namespace import ::tcltest::*

proc featureRoundtrip {tag script} {
    set out [makeFile "" ${tag}-out.tbcx]
    tbcx::save $script $out
    interp create FT_$tag
    interp eval FT_$tag [list package require tbcx]
    interp eval FT_$tag {proc exit {args} {error "exit $args"}}
    set rc [interp eval FT_$tag [list catch [list tbcx::load $out] _r _o]]
    set pass 0; set fail 0; set errors {}
    catch {set pass [interp eval FT_$tag {set ::_pass}]}
    catch {set fail [interp eval FT_$tag {set ::_fail}]}
    if {$fail > 0} { catch {set errors [interp eval FT_$tag {set ::_errors}]} }
    set loadErr ""
    if {$rc != 0} { catch {set loadErr [interp eval FT_$tag {set _r}]} }
    interp delete FT_$tag
    if {$rc != 0} { error "load error after $pass ok: $loadErr" }
    if {$fail != 0} { error "$fail failures out of [expr {$pass+$fail}]: $errors" }
    return $pass
}

set H {
set ::_pass 0; set ::_fail 0; set ::_errors {}
proc assert {tag got expected} {
    if {$got eq $expected} { incr ::_pass } else {
        incr ::_fail; lappend ::_errors "$tag: got=$got exp=$expected"
    }
}
}

# === 1. Grammar ===
test af.1 {grammar: substitution and quoting} -body {
    set script $H
    append script {
        set x 42
        assert var-scalar $x 42
        set arr(k) hello
        assert var-array $arr(k) hello
        assert cmd-subst [expr {1+2}] 3
        assert nested-subst [string length [expr {1+2}]] 1
        assert brace-quote {no $subst here} {no $subst here}
        assert dquote-subst "val=$x" val=42
        set a 1; set b 2
        assert semicolon [expr {$a + $b}] 3
        assert backslash-tab "a\tb" "a\tb"
        assert backslash-nl "a\nb" "a\nb"
        set r [format %c 0xe9]
        assert unicode-escape [string length $r] 1
    }
    featureRoundtrip af1 $script
} -match glob -result {1*}

# === 2. Data types ===
test af.2 {data types: all literal types} -body {
    set script $H
    append script {
        assert str hello hello
        assert int [expr {42}] 42
        assert wide [expr {9223372036854775807}] 9223372036854775807
        assert bignum [expr {2**80}] 1208925819614629174706176
        assert dbl [expr {3.14}] 3.14
        assert bool-t [expr {true}] true
        assert bool-f [expr {false}] false
        assert list [list a b c] {a b c}
        assert dict [dict get [dict create k v] k] v
        assert empty-str {} {}
        assert empty-list [list] {}
        assert bytearray [string length [binary format c* {1 2 3}]] 3
    }
    featureRoundtrip af2 $script
} -result 12

# === 3. Expressions ===
test af.3 {expressions: all operator families} -body {
    set script $H
    append script {
        assert add [expr {3 + 4}] 7
        assert sub [expr {10 - 3}] 7
        assert mul [expr {6 * 7}] 42
        assert div [expr {15 / 4}] 3
        assert mod [expr {17 % 5}] 2
        assert pow [expr {2**10}] 1024
        assert neg [expr {-42}] -42

        assert eq [expr {3 == 3}] 1
        assert ne [expr {3 != 4}] 1
        assert lt [expr {2 < 3}] 1
        assert gt [expr {4 > 3}] 1
        assert le [expr {3 <= 3}] 1
        assert ge [expr {4 >= 3}] 1

        assert and [expr {1 && 1}] 1
        assert or  [expr {0 || 1}] 1
        assert not [expr {!0}] 1

        assert band [expr {0xFF & 0x0F}] 15
        assert bor  [expr {0xF0 | 0x0F}] 255
        assert bxor [expr {0xFF ^ 0xFF}] 0
        assert bnot [expr {~0 & 0xFF}] 255
        assert shl  [expr {1 << 8}] 256
        assert shr  [expr {256 >> 8}] 1

        assert ternary [expr {1 ? "yes" : "no"}] yes
        assert in  [expr {"b" in {a b c}}] 1
        assert ni  [expr {"z" ni {a b c}}] 1

        assert abs [expr {abs(-5)}] 5
        assert max [expr {max(3,7)}] 7
        assert min [expr {min(3,7)}] 3
        assert int-fn [expr {int(3.9)}] 3
        assert double-fn [expr {double(5)}] 5.0
        assert sqrt [expr {int(sqrt(144))}] 12
    }
    featureRoundtrip af3 $script
} -result 31

# === 4. Variables ===
test af.4 {variables: set, unset, append, incr, array} -body {
    set script $H
    append script {
        set x 10; assert set-basic $x 10
        unset x; assert unset-gone [info exists x] 0
        set s {}; append s a b c; assert append $s abc
        set n 0; incr n; incr n 5; incr n -2; assert incr $n 4
        set l {}; lappend l x y z; assert lappend $l {x y z}
        set a(one) 1; set a(two) 2
        assert array-get $a(one) 1
        assert array-size [array size a] 2
        assert array-names [lsort [array names a]] {one two}
    }
    featureRoundtrip af4 $script
} -result 8

# === 5. Strings ===
test af.5 {strings: length, index, range, map, trim, repeat, reverse} -body {
    set script $H
    append script {
        assert slen [string length abcde] 5
        assert sidx [string index abcde 2] c
        assert srng [string range abcde 1 3] bcd
        assert smap [string map {a X b Y} abc] XYc
        assert strim [string trim "  hello  "] hello
        assert srepeat [string repeat ab 3] ababab
        assert sreverse [string reverse abcde] edcba
        assert supper [string toupper hello] HELLO
        assert slower [string tolower HELLO] hello
        assert sfirst [string first bc abcde] 1
        assert slast [string last e abcde] 4
        assert smatch [string match {h*o} hello] 1
        assert sis-int [string is integer 42] 1
        assert sis-alpha [string is alpha abc] 1
        assert sreplace [string replace abcde 1 3 XYZ] aXYZe
    }
    featureRoundtrip af5 $script
} -result 15

# === 6. Lists ===
test af.6 {lists: lindex, lrange, lsort, lsearch, lreplace, linsert, lmap} -body {
    set script $H
    append script {
        set l {c a b e d}
        assert lindex [lindex $l 2] b
        assert lrange [lrange $l 1 3] {a b e}
        assert lsort [lsort $l] {a b c d e}
        assert lsearch [lsearch $l b] 2
        assert lreplace [lreplace $l 2 2 X] {c a X e d}
        assert linsert [linsert $l 0 z] {z c a b e d}
        assert lreverse [lreverse {1 2 3}] {3 2 1}
        assert lrepeat [lrepeat 3 x] {x x x}
        assert ljoin [join {a b c} -] a-b-c
        assert lmap [lmap x {1 2 3} {expr {$x * 2}}] {2 4 6}
    }
    featureRoundtrip af6 $script
} -result 10

# === 7. Dicts ===
test af.7 {dicts: create, get, set, exists, update, for, map} -body {
    set script $H
    append script {
        set d [dict create a 1 b 2 c 3]
        assert dict-get [dict get $d b] 2
        assert dict-size [dict size $d] 3
        assert dict-exists [dict exists $d c] 1
        assert dict-keys [lsort [dict keys $d]] {a b c}
        assert dict-values [lsort [dict values $d]] {1 2 3}
        dict set d d 4
        assert dict-set [dict get $d d] 4
        dict update d a A b B { set A 10; set B 20 }
        assert dict-update-a [dict get $d a] 10
        set sum 0
        dict for {k v} $d { incr sum $v }
        assert dict-for $sum 37
        set m [dict map {k v} [dict create x 1 y 2] { expr {$v * 10} }]
        assert dict-map [dict get $m x] 10
    }
    featureRoundtrip af7 $script
} -result 9

# === 8. Control flow ===
test af.8 {control flow: if, while, for, foreach, switch, try} -body {
    set script $H
    append script {
        assert if-t [if {1} {set _ yes} else {set _ no}] yes
        assert if-f [if {0} {set _ yes} else {set _ no}] no

        set s 0; set i 0
        while {$i < 10} { incr s $i; incr i }
        assert while $s 45

        set s 0
        for {set i 0} {$i < 5} {incr i} { incr s $i }
        assert for $s 10

        set r {}
        foreach x {a b c} { lappend r $x }
        assert foreach $r {a b c}

        foreach {a b} {1 2 3 4} {}
        assert foreach-multi [list $a $b] {3 4}

        set sw [switch -exact -- b { a {set _ A} b {set _ B} c {set _ C} }]
        assert switch $sw B

        set tr [try { expr {10 / 2} } on error {} { set _ -1 }]
        assert try-ok $tr 5
        set tr [try { expr {10 / 0} } on error {} { set _ -1 }]
        assert try-err $tr -1

        set n 0; while {$n < 100} { incr n; if {$n == 5} break }
        assert break $n 5

        set evens 0; set j 0
        while {$j < 10} { incr j; if {$j % 2} continue; incr evens }
        assert continue $evens 5
    }
    featureRoundtrip af8 $script
} -result 11

# === 9. Procs ===
test af.9 {procs: all signature forms} -body {
    set script $H
    append script {
        proc p0 {} { return zero }
        proc p1 {x} { return $x }
        proc p2 {x {y 10}} { expr {$x + $y} }
        proc pv {args} { llength $args }
        proc pm {a b args} { list $a $b [llength $args] }
        assert p0 [p0] zero
        assert p1 [p1 hello] hello
        assert p2-def [p2 5] 15
        assert p2-given [p2 5 20] 25
        assert pv [pv a b c] 3
        assert pm [pm x y a b c] {x y 3}
        proc fact {n} { if {$n <= 1} {return 1}; expr {$n * [fact [expr {$n-1}]]} }
        assert recursive [fact 10] 3628800
    }
    featureRoundtrip af9 $script
} -result 7

# === 10. Scoping ===
test af.10 {scoping: global, variable, upvar, uplevel} -body {
    set script $H
    append script {
        set ::gv 100
        proc read_global {} { global gv; return $gv }
        assert global [read_global] 100
        namespace eval ::scopens { variable nsvar 42 }
        proc read_nsvar {} { return $::scopens::nsvar }
        assert nsvar [read_nsvar] 42
        proc doinc {name} { upvar 1 $name v; incr v 10 }
        set x 5; doinc x
        assert upvar $x 15
        proc runhere {s} { uplevel 1 $s }
        set y 0; runhere {set y 99}
        assert uplevel $y 99
    }
    featureRoundtrip af10 $script
} -result 4

# === 11. Namespaces ===
test af.11 {namespaces: nested, variable, import} -body {
    set script $H
    append script {
        namespace eval ::af11a::b::c {
            variable deep 1
            proc getdeep {} { variable deep; return $deep }
        }
        assert ns-deep [::af11a::b::c::getdeep] 1
        namespace eval ::af11ns1 {
            proc helper {} { return ns1-ok }
            namespace export helper
        }
        namespace eval ::af11ns2 {
            namespace import ::af11ns1::helper
        }
        assert ns-import [::af11ns2::helper] ns1-ok
        namespace eval ::af11counter {
            variable n 0
            proc bump {} { variable n; incr n }
            proc val {} { variable n; return $n }
        }
        ::af11counter::bump; ::af11counter::bump; ::af11counter::bump
        assert ns-counter [::af11counter::val] 3
    }
    featureRoundtrip af11 $script
} -result 3

# === 12. Regexp ===
test af.12 {regexp and regsub} -body {
    set script $H
    append script {
        assert re-match [regexp {^\d+$} 12345] 1
        assert re-nomatch [regexp {^\d+$} abc] 0
        regexp {(\w+)@(\w+)} {user@host} -> u h
        assert re-capture-u $u user
        assert re-capture-h $h host
        assert regsub [regsub -all {[aeiou]} hello *] h*ll*
        assert regsub-count [regsub -all {o} {foo boo} X _] 4
    }
    featureRoundtrip af12 $script
} -result 6

# === 13. eval, subst ===
test af.13 {eval and subst} -body {
    set script $H
    append script {
        assert eval [eval {expr {6 * 7}}] 42
        set who World
        assert subst [subst {Hello $who}] {Hello World}
        assert subst-cmd [subst {1+2=[expr {1+2}]}] {1+2=3}
        assert subst-novar [subst -nocommands -novariables {literal}] literal
    }
    featureRoundtrip af13 $script
} -result 4

# === 14. Lambda ===
test af.14 {lambda: basic, namespace, higher-order} -body {
    set script $H
    append script {
        assert lam-basic [apply {{x} {expr {$x+1}}} 41] 42
        assert lam-multi [apply {{a b} {expr {$a*$b}}} 6 7] 42
        assert lam-default [apply {{x {y 10}} {expr {$x+$y}}} 5] 15
        namespace eval ::af14lamns { variable factor 3 }
        assert lam-ns [apply {{x} {expr {$x * $::af14lamns::factor}} ::af14lamns} 14] 42
        set adder [list {a b} {expr {$a+$b}}]
        assert lam-var [apply $adder 20 22] 42
    }
    featureRoundtrip af14 $script
} -result 5

# === 15. Coroutines ===
test af.15 {coroutines: yield, generator, send} -body {
    set script $H
    append script {
        proc af15counter {} { set i 0; while 1 { yield $i; incr i } }
        coroutine af15cnt af15counter
        assert coro-basic [list [af15cnt] [af15cnt] [af15cnt]] {1 2 3}
        rename af15cnt {}

        proc af15fib {} {
            set a 0; set b 1
            while 1 {
                yield $a
                lassign [list $b [expr {$a+$b}]] a b
            }
        }
        coroutine af15f af15fib
        set r {}; for {set i 0} {$i < 7} {incr i} { lappend r [af15f] }
        assert coro-fib $r {1 1 2 3 5 8 13}
        rename af15f {}

        proc af15accum {} {
            set total 0
            while 1 { set v [yield $total]; incr total $v }
        }
        coroutine af15acc af15accum
        af15acc 0; af15acc 10; af15acc 20
        assert coro-send [af15acc 5] 35
        rename af15acc {}
    }
    featureRoundtrip af15 $script
} -result 3

# === 16. tailcall ===
test af.16 {tailcall: basic and recursive} -body {
    set script $H
    append script {
        proc af16inner {x} { expr {$x * 2} }
        proc af16outer {x} { tailcall af16inner $x }
        assert tc-basic [af16outer 21] 42
        proc af16tcloop {n acc} {
            if {$n <= 0} { return $acc }
            tailcall af16tcloop [expr {$n-1}] [expr {$acc+$n}]
        }
        assert tc-recurse [af16tcloop 100 0] 5050
    }
    featureRoundtrip af16 $script
} -result 2

# === 17. Binary ===
test af.17 {binary: format and scan} -body {
    set script $H
    append script {
        set p [binary format i 42]
        binary scan $p i v
        assert bin-int $v 42
        set p [binary format a5 hello]
        binary scan $p a5 s
        assert bin-str $s hello
        set p [binary format d 3.14]
        binary scan $p d d
        assert bin-dbl [expr {abs($d - 3.14) < 1e-10}] 1
        set p [binary format c3 {65 66 67}]
        binary scan $p a3 s
        assert bin-bytes $s ABC
    }
    featureRoundtrip af17 $script
} -result 4

# === 18. Encoding ===
test af.18 {encoding: convertto and convertfrom} -body {
    set script $H
    append script {
        set utf8 [encoding convertto utf-8 ABC]
        assert enc-to [encoding convertfrom utf-8 $utf8] ABC
        set ustr [format %c 0xe9]
        set bytes [encoding convertto utf-8 $ustr]
        assert enc-unicode [encoding convertfrom utf-8 $bytes] $ustr
    }
    featureRoundtrip af18 $script
} -result 2

# === 19. Info ===
test af.19 {info: commands, procs, args, exists} -body {
    set script $H
    append script {
        proc af19sample {a b {c 0}} { return ok }
        assert info-args [info args af19sample] {a b c}
        assert info-default [info default af19sample c def; set def] 0
        assert info-exists-y [set _v 1; info exists _v] 1
        assert info-exists-n [info exists _nonexistent_var_xyz] 0
        assert info-level [info level] 0
        assert info-cmdcount [expr {[info cmdcount] > 0}] 1
    }
    featureRoundtrip af19 $script
} -result 6

# === 20. OO advanced interaction — split into sub-tests for crash isolation ===
test af.20a {OO: basic class with variable + constructor + method} -body {
    set script $H
    append script {
        oo::class create Af20aLogger {
            variable log
            constructor {} { set log {} }
            method entries {} { return $log }
            method record {msg} { lappend log $msg }
        }
        set o [Af20aLogger new]
        $o record hello
        assert oo-basic-log [$o entries] hello
    }
    featureRoundtrip af20a $script
} -result 1

test af.20b {OO: superclass with next in constructor} -body {
    set script $H
    append script {
        oo::class create Af20bBase {
            variable log
            constructor {} { set log {} }
            method entries {} { return $log }
            method record {msg} { lappend log $msg }
        }
        oo::class create Af20bChild {
            superclass Af20bBase
            constructor {} { next; my record created }
        }
        set s [Af20bChild new]
        assert oo-next-ctor [$s entries] created
    }
    featureRoundtrip af20b $script
} -result 1

test af.20c {OO: classmethod} -body {
    set script $H
    append script {
        oo::class create Af20cThing {
            classmethod kind {} { return thing }
        }
        assert oo-classmethod [Af20cThing kind] thing
    }
    featureRoundtrip af20c $script
} -result 1

test af.20d {OO: private method} -body {
    set script $H
    append script {
        oo::class create Af20dBox {
            method pub {} { my helper; return ok }
            private method helper {} { }
        }
        set b [Af20dBox new]
        assert oo-private-pub [$b pub] ok
        assert oo-private-blocked [catch {$b helper}] 1
    }
    featureRoundtrip af20d $script
} -result 2

test af.20e1 {OO: superclass + classmethod (no private)} -body {
    set script $H
    append script {
        oo::class create Af20e1Base {
            variable log
            constructor {} { set log {} }
            method entries {} { return $log }
            method record {msg} { lappend log $msg }
        }
        oo::class create Af20e1Child {
            superclass Af20e1Base
            classmethod kind {} { return child }
            constructor {} { next; my record created }
            method api {} { my record api-call; return ok }
        }
        set s [Af20e1Child new]
        assert e1-cm [Af20e1Child kind] child
        assert e1-api [$s api] ok
        assert e1-log [$s entries] {created api-call}
    }
    featureRoundtrip af20e1 $script
} -result 3

test af.20e2 {OO: superclass + private (no classmethod)} -body {
    set script $H
    append script {
        oo::class create Af20e2Base {
            variable log
            constructor {} { set log {} }
            method entries {} { return $log }
            method record {msg} { lappend log $msg }
        }
        oo::class create Af20e2Child {
            superclass Af20e2Base
            constructor {} { next; my record created }
            method api {} { my record api-call; my helper; return ok }
            private method helper {} { my record helper-done }
        }
        set s [Af20e2Child new]
        assert e2-api [$s api] ok
        assert e2-log [$s entries] {created api-call helper-done}
    }
    featureRoundtrip af20e2 $script
} -result 2

test af.20e3 {OO: classmethod + private (no superclass)} -body {
    set script $H
    append script {
        oo::class create Af20e3Thing {
            classmethod kind {} { return thing }
            method api {} { my helper; return ok }
            private method helper {} { }
        }
        assert e3-cm [Af20e3Thing kind] thing
        set t [Af20e3Thing new]
        assert e3-api [$t api] ok
    }
    featureRoundtrip af20e3 $script
} -result 2

test af.20e4 {OO: all three — superclass + classmethod + private} -body {
    set script $H
    append script {
        oo::class create Af20e4Base {
            variable log
            constructor {} { set log {} }
            method entries {} { return $log }
            method record {msg} { lappend log $msg }
        }
        oo::class create Af20e4Svc {
            superclass Af20e4Base
            classmethod kind {} { return service }
            constructor {} { next; my record created }
            method api {} { my record api-call; my helper; return ok }
            private method helper {} { my record helper-done }
        }
        set s [Af20e4Svc new]
        assert e4-cm [Af20e4Svc kind] service
        assert e4-api [$s api] ok
        assert e4-log [$s entries] {created api-call helper-done}
        assert e4-priv [catch {$s helper}] 1
    }
    featureRoundtrip af20e4 $script
} -result 4

# === 21. OO: deletemethod, renamemethod, unexport ===
test af.21 {OO: deletemethod, renamemethod, unexport} -body {
    set script $H
    append script {
        oo::class create Af21Mutable
        oo::define Af21Mutable {
            method keep {} { return kept }
            method temp {} { return temp }
            method internal {} { return int }
            method pub {} { return [my internal] }
            method oldname {} { return old }
        }
        oo::define Af21Mutable deletemethod temp
        oo::define Af21Mutable renamemethod oldname newname
        oo::define Af21Mutable unexport internal
        set o [Af21Mutable new]
        assert del-keep [$o keep] kept
        assert del-temp [catch {$o temp}] 1
        assert rename [$o newname] old
        assert unexport-via-pub [$o pub] int
        assert unexport-direct [catch {$o internal}] 1
    }
    featureRoundtrip af21 $script
} -result 5

# === 22. OO: objdefine, copy, abstract, singleton ===
test af.22 {OO: objdefine, copy, abstract, singleton} -body {
    set script $H
    append script {
        oo::class create Af22Base
        oo::define Af22Base method m {} { return base }
        set o [Af22Base new]
        oo::objdefine $o method extra {} { return per-object }
        assert objdefine [$o extra] per-object
        set cp [oo::copy $o]
        assert copy [$cp m] base
        oo::abstract create Af22Abs
        oo::define Af22Abs method am {} { return abs }
        oo::class create Af22Conc {superclass Af22Abs}
        set ac [Af22Conc new]
        assert abstract [$ac am] abs
        assert abstract-noinstantiate [catch {Af22Abs new}] 1
        oo::singleton create Af22Sing
        oo::define Af22Sing {
            constructor {} { my variable data; set data {} }
            method add {v} { my variable data; lappend data $v }
            method all {} { my variable data; return $data }
        }
        set s1 [Af22Sing new]; $s1 add x
        set s2 [Af22Sing new]; $s2 add y
        assert singleton [$s1 all] {x y}
    }
    featureRoundtrip af22 $script
} -result 5

# === 23. Complex: closures, dispatch ===
test af.23 {complex: closures and dispatch tables} -body {
    set script $H
    append script {
        proc af23_make_adder {n} { list {x} [format {expr {$x + %d}} $n] }
        set add5 [af23_make_adder 5]
        set add10 [af23_make_adder 10]
        assert closure-5 [apply $add5 3] 8
        assert closure-10 [apply $add10 3] 13
        proc af23_op_add {a b} { expr {$a + $b} }
        proc af23_op_mul {a b} { expr {$a * $b} }
        proc af23_dispatch {op a b} { af23_op_$op $a $b }
        assert dispatch-add [af23_dispatch add 3 4] 7
        assert dispatch-mul [af23_dispatch mul 3 4] 12
    }
    featureRoundtrip af23 $script
} -result 4

# === 24. namespace + OO + lambda ===
test af.24 {complex: namespace + OO + lambda combined} -body {
    set script $H
    append script {
        namespace eval ::af24pkg {
            variable version 2.0
            oo::class create Widget
            oo::define Widget {
                constructor {n} { my variable name; set name $n }
                method describe {} {
                    my variable name
                    return "$name v$::af24pkg::version"
                }
            }
            proc make {name} { Widget new $name }
        }
        set w [::af24pkg::make TestWidget]
        assert ns-oo-lam [$w describe] {TestWidget v2.0}
        set mapper [list {x} {expr {$x * $::af24pkg::version}}]
        assert ns-lambda [apply $mapper 21] 42.0
    }
    featureRoundtrip af24 $script
} -result 2

# === 25. Exceptions: nested try/catch in loops ===
test af.25 {exceptions: nested try/catch in loops} -body {
    set script $H
    append script {
        proc af25safediv {pairs} {
            set results {}
            foreach pair $pairs {
                lassign $pair a b
                try {
                    lappend results [expr {$a / $b}]
                } on error {} {
                    lappend results ERR
                }
            }
            return $results
        }
        assert exc-loop [af25safediv {{10 2} {10 0} {20 4} {1 0}}] {5 ERR 5 ERR}

        proc af25nested {} {
            try {
                try { error inner } on error {msg} { set r caught-$msg }
                return $r
            } on error {msg} { return outer-$msg }
        }
        assert exc-nested [af25nested] caught-inner

        set result {}
        for {set i 0} {$i < 5} {incr i} {
            try {
                if {$i == 2} { error skip }
                lappend result $i
            } on error {} {
                lappend result X
            }
        }
        assert exc-for $result {0 1 X 3 4}
    }
    featureRoundtrip af25 $script
} -result 3

# === 26. Deep nesting ===
test af.26 {stress: deeply nested mixed patterns} -body {
    set script $H
    append script {
        namespace eval ::af26deep {
            proc compute {n} {
                set total 0
                foreach i [lmap x [lrepeat $n 1] {expr {$x}}] {
                    try { incr total $i } on error {} {}
                }
                return $total
            }
        }
        assert deep-mixed [::af26deep::compute 100] 100
        proc af26recnest {n} {
            if {$n <= 0} { return done }
            return [af26recnest [expr {$n - 1}]]
        }
        assert deep-recurse [af26recnest 50] done
    }
    featureRoundtrip af26 $script
} -result 2

# === 27. OO: filter + mixin + forward ===
test af.27 {OO: filter + mixin + forward combined} -body {
    set script $H
    append script {
        oo::class create Af27Describable
        oo::define Af27Describable method describe {} { return [self class] }
        oo::class create Af27Thing
        oo::define Af27Thing {
            mixin Af27Describable
            forward len string length
            method check {s} { my len $s }
        }
        set t [Af27Thing new]
        assert mix-describe [$t describe] ::Af27Describable
        assert fwd-len [$t check hello] 5
    }
    featureRoundtrip af27 $script
} -result 2

# === 28. Data pipeline ===
test af.28 {complex: data pipeline with list/dict/lmap} -body {
    set script $H
    append script {
        set records {
            {name Alice score 85}
            {name Bob score 92}
            {name Carol score 78}
            {name Dave score 95}
        }
        set scores [lmap r $records {dict get $r score}]
        set total 0; foreach s $scores { incr total $s }
        set avg [expr {$total / [llength $scores]}]
        assert pipeline-avg $avg 87
        set high [lmap r $records {
            set s [dict get $r score]
            if {$s >= 90} { dict get $r name } else { continue }
        }]
        assert pipeline-high [lsort $high] {Bob Dave}
    }
    featureRoundtrip af28 $script
} -result 2

cleanupTests

