# -*-Tcl-*-
package require tbcx
package require tcltest 2.5
namespace import ::tcltest::*

# Apply with namespace
test adv.1 {apply with namespace qualifier} -body {
    set in  [makeFile {
        namespace eval ::myns {}
        set fn [list x {expr {$x * 10}} ::myns]
        return [apply $fn 4]
    } adv.1-in.tcl]
    set out [makeFile "" adv.1-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 40

# Higher-order: filter
test adv.2 {higher-order filter with apply} -body {
    set in  [makeFile {
        proc filter {fn lst} {
            set res {}
            foreach x $lst {
                if {[apply $fn $x]} { lappend res $x }
            }
            return $res
        }
        return [filter {x {expr {$x > 3}}} {1 2 3 4 5 6}]
    } adv.2-in.tcl]
    set out [makeFile "" adv.2-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {4 5 6}

# Higher-order: map
test adv.3 {higher-order map} -body {
    set in  [makeFile {
        proc mymap {fn lst} {
            set res {}
            foreach x $lst {
                lappend res [apply $fn $x]
            }
            return $res
        }
        return [mymap {x {string toupper $x}} {hello world foo}]
    } adv.3-in.tcl]
    set out [makeFile "" adv.3-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {HELLO WORLD FOO}

# Higher-order: reduce/fold
test adv.4 {higher-order reduce} -body {
    set in  [makeFile {
        proc reduce {fn init lst} {
            set acc $init
            foreach x $lst {
                set acc [apply $fn $acc $x]
            }
            return $acc
        }
        return [reduce {{a b} {expr {$a + $b}}} 0 {1 2 3 4 5}]
    } adv.4-in.tcl]
    set out [makeFile "" adv.4-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 15

# Multiple classes with inheritance chain
test adv.5 {OO: inheritance chain} -body {
    set in  [makeFile {
        oo::class create Shape
        oo::define Shape method type {} {return shape}
        oo::class create Rectangle {superclass Shape}
        oo::define Rectangle method type {} {return rectangle}
        oo::class create Square {superclass Rectangle}
        oo::define Square method type {} {return square}
        set s [Square new]
        return [$s type]
    } adv.5-in.tcl]
    set out [makeFile "" adv.5-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result square

# OO with next (superclass method call)
test adv.6 {OO: next for superclass delegation} -body {
    set in  [makeFile {
        oo::class create Logger
        oo::define Logger method log {msg} {return "LOG:$msg"}
        oo::class create PrefixLogger {superclass Logger}
        oo::define PrefixLogger method log {msg} {
            return [next "PREFIX:$msg"]
        }
        set l [PrefixLogger new]
        return [$l log hello]
    } adv.6-in.tcl]
    set out [makeFile "" adv.6-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result LOG:PREFIX:hello

# Proc generating procs
test adv.7 {metaprogramming: proc creating procs} -body {
    set in  [makeFile {
        proc make_adder {n} {
            proc "add$n" {x} "expr \{\$x + $n\}"
        }
        make_adder 10
        make_adder 20
        return [list [add10 5] [add20 5]]
    } adv.7-in.tcl]
    set out [makeFile "" adv.7-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {15 25}

# Complex data structure (list of dicts)
test adv.8 {complex data: list of dicts} -body {
    set in  [makeFile {
        proc make_person {name age} {
            dict create name $name age $age
        }
        set people [list [make_person Alice 30] [make_person Bob 25]]
        set names {}
        foreach p $people {
            lappend names [dict get $p name]
        }
        return $names
    } adv.8-in.tcl]
    set out [makeFile "" adv.8-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {Alice Bob}

# String is command
test adv.9 {string is: type checking} -body {
    set in  [makeFile {
        return [list \
            [string is integer 42] \
            [string is integer abc] \
            [string is double 3.14] \
            [string is alpha hello] \
            [string is alpha "hello world"]]
    } adv.9-in.tcl]
    set out [makeFile "" adv.9-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {1 0 1 1 0}

# Binary format/scan roundtrip
test adv.10 {binary: format and scan} -body {
    set in  [makeFile {
        set packed [binary format "ii" 12345 67890]
        binary scan $packed "ii" a b
        return [list $a $b]
    } adv.10-in.tcl]
    set out [makeFile "" adv.10-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {12345 67890}

# Ternary chained
test adv.11 {chained ternary expressions} -body {
    set in  [makeFile {
        proc sign {x} {
            expr {$x > 0 ? "positive" : $x < 0 ? "negative" : "zero"}
        }
        return [list [sign 5] [sign -3] [sign 0]]
    } adv.11-in.tcl]
    set out [makeFile "" adv.11-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {positive negative zero}

# Clock operations
test adv.12 {clock: format and scan} -body {
    set in  [makeFile {
        set t [clock scan "2025-06-15" -format "%Y-%m-%d" -gmt 1]
        return [clock format $t -format "%Y-%m-%d" -gmt 1]
    } adv.12-in.tcl]
    set out [makeFile "" adv.12-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 2025-06-15

# Interp alias (command aliasing)
test adv.13 {interp alias} -body {
    set in  [makeFile {
        proc myadd {a b} {expr {$a + $b}}
        interp alias {} plus {} myadd
        return [plus 10 20]
    } adv.13-in.tcl]
    set out [makeFile "" adv.13-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 30

# Complex: Fibonacci memoized
test adv.14 {memoized fibonacci} -body {
    set in  [makeFile {
        proc fib {n} {
            if {[info exists ::memo($n)]} {return $::memo($n)}
            if {$n <= 1} {set ::memo($n) $n; return $n}
            set ::memo($n) [expr {[fib [expr {$n-1}]] + [fib [expr {$n-2}]]}]
            return $::memo($n)
        }
        return [fib 20]
    } adv.14-in.tcl]
    set out [makeFile "" adv.14-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 6765

# ---- Coroutines ----

test adv.15 {coroutine: basic yield/resume} -body {
    set out [makeFile "" adv.15-out.tbcx]
    tbcx::save {
        proc counter {} {
            set i 0
            while 1 {
                yield $i
                incr i
            }
        }
        coroutine gen counter
        set r [list [gen] [gen] [gen] [gen]]
        rename gen {}
        return $r
    } $out
    tbcx::load $out
} -result {1 2 3 4}

test adv.16 {coroutine: generator pattern} -body {
    set out [makeFile "" adv.16-out.tbcx]
    tbcx::save {
        proc fibonacci {} {
            set a 0; set b 1
            while 1 {
                yield $a
                lassign [list $b [expr {$a + $b}]] a b
            }
        }
        coroutine fib fibonacci
        set r {}
        for {set i 0} {$i < 8} {incr i} { lappend r [fib] }
        rename fib {}
        return $r
    } $out
    tbcx::load $out
} -result {1 1 2 3 5 8 13 21}

test adv.17 {coroutine: send values to coroutine} -body {
    set out [makeFile "" adv.17-out.tbcx]
    tbcx::save {
        proc accumulator {} {
            set total 0
            while 1 {
                set val [yield $total]
                incr total $val
            }
        }
        coroutine acc accumulator
        acc 0 ;# prime (send 0 — yield returns this to incr)
        acc 10
        acc 20
        set r [acc 5]
        rename acc {}
        return $r
    } $out
    tbcx::load $out
} -result 35

# ---- Tailcall ----

test adv.18 {tailcall: basic} -body {
    set out [makeFile "" adv.18-out.tbcx]
    tbcx::save {
        proc inner {x} { return [expr {$x * 2}] }
        proc outer {x} { tailcall inner $x }
        return [outer 21]
    } $out
    tbcx::load $out
} -result 42

test adv.19 {tailcall: recursive with tail optimization} -body {
    set out [makeFile "" adv.19-out.tbcx]
    tbcx::save {
        proc tloop {n acc} {
            if {$n <= 0} { return $acc }
            tailcall tloop [expr {$n - 1}] [expr {$acc + $n}]
        }
        return [tloop 100 0]
    } $out
    tbcx::load $out
} -result 5050

# ---- Binary format/scan ----

test adv.20 {binary: format and scan integers} -body {
    set out [makeFile "" adv.20-out.tbcx]
    tbcx::save {
        set packed [binary format i2 {42 100}]
        binary scan $packed i2 vals
        return $vals
    } $out
    tbcx::load $out
} -result {42 100}

test adv.21 {binary: format and scan mixed types} -body {
    set out [makeFile "" adv.21-out.tbcx]
    tbcx::save {
        set packed [binary format a5c hello 65]
        binary scan $packed a5c str byte
        return [list $str $byte]
    } $out
    tbcx::load $out
} -result {hello 65}

test adv.22 {binary: scan float} -body {
    set out [makeFile "" adv.22-out.tbcx]
    tbcx::save {
        set packed [binary format d 3.14]
        binary scan $packed d val
        return [expr {abs($val - 3.14) < 1e-10}]
    } $out
    tbcx::load $out
} -result 1

# ---- Scoping: upvar, uplevel, global, variable ----

test adv.23 {uplevel: run script in caller's frame} -body {
    set out [makeFile "" adv.23-out.tbcx]
    tbcx::save {
        proc runup {script} { uplevel 1 $script }
        set x 10
        runup {set x [expr {$x * 2}]}
        return $x
    } $out
    tbcx::load $out
} -result 20

test adv.24 {upvar: nested upvar chain} -body {
    set out [makeFile "" adv.24-out.tbcx]
    tbcx::save {
        proc level2 {name} {
            upvar 1 $name v
            incr v 100
        }
        proc level1 {name} {
            upvar 1 $name v
            level2 v
        }
        set myvar 5
        level1 myvar
        return $myvar
    } $out
    tbcx::load $out
} -result 105

# ---- Info introspection ----

test adv.25 {info: body and args after roundtrip} -body {
    set out [makeFile "" adv.25-out.tbcx]
    tbcx::save {
        proc sample {a b {c 0}} { return [expr {$a + $b + $c}] }
        set args [info args sample]
        return [list [llength $args] [lindex $args 2]]
    } $out
    tbcx::load $out
} -result {3 c}

# ---- subst ----

test adv.26 {subst: variable and command substitution} -body {
    set out [makeFile "" adv.26-out.tbcx]
    tbcx::save {
        set who "World"
        return [subst {Hello $who, 1+2=[expr {1+2}]}]
    } $out
    tbcx::load $out
} -result {Hello World, 1+2=3}

# ---- encoding ----

test adv.27 {encoding: convertto and convertfrom} -body {
    set out [makeFile "" adv.27-out.tbcx]
    tbcx::save {
        set utf8 [encoding convertto utf-8 "ABC"]
        set back [encoding convertfrom utf-8 $utf8]
        return $back
    } $out
    tbcx::load $out
} -result ABC

# ---- Complex patterns ----

test adv.28 {complex: closure via namespace + apply} -body {
    set out [makeFile "" adv.28-out.tbcx]
    tbcx::save {
        proc make_adder {n} {
            return [list {x} [format {expr {$x + %d}} $n]]
        }
        set add5 [make_adder 5]
        set add10 [make_adder 10]
        return [list [apply $add5 3] [apply $add10 3]]
    } $out
    tbcx::load $out
} -result {8 13}

test adv.29 {complex: dispatch table with procs} -body {
    set out [makeFile "" adv.29-out.tbcx]
    tbcx::save {
        proc op_add {a b} { expr {$a + $b} }
        proc op_mul {a b} { expr {$a * $b} }
        proc op_sub {a b} { expr {$a - $b} }
        proc dispatch {op a b} {
            set cmd "op_$op"
            $cmd $a $b
        }
        return [list [dispatch add 3 4] [dispatch mul 3 4] [dispatch sub 10 3]]
    } $out
    tbcx::load $out
} -result {7 12 7}

test adv.30 {complex: data pipeline with list/dict ops} -body {
    set out [makeFile "" adv.30-out.tbcx]
    tbcx::save {
        set data {
            {name Alice age 30 score 85}
            {name Bob age 25 score 92}
            {name Carol age 35 score 78}
        }
        set total 0
        set count 0
        foreach record $data {
            incr total [dict get $record score]
            incr count
        }
        return [expr {$total / $count}]
    } $out
    tbcx::load $out
} -result 85

cleanupTests
