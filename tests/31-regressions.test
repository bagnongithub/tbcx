# -*-Tcl-*-
# 31-regressions.test — assorted correctness checks.
#
#   A. List-literal first-element quoting: a constant-folded [list …] whose
#      first element needs list-quoting (leading '#', leading space, embedded
#      braces) must round-trip without re-quoting (a scalar carrying a parasitic
#      list internal rep must not be re-serialized element-wise, e.g. "#aa" must
#      not become "{#aa}").
#
#   B. TclOO in-body `export` visibility: a method exported via the `export`
#      command INSIDE an `oo::class create {…}` / `oo::define {…}` body keeps its
#      public visibility on load (PrecompClass restores both the export and the
#      unexport direction), so a PascalCase callback (e.g. DoFlush) stays
#      externally dispatchable.

package require tbcx
package require tcltest 2.5
namespace import ::tcltest::*

# ---------------------------------------------------------------------------
# A. List-literal first-element quoting
# ---------------------------------------------------------------------------

test regress.list.0 {first element leading '#' (colour) round-trips} -body {
    set in  [makeFile {return [lindex [list "#fde9e9" "#641e1e" "#c0392b"] 0]} regress.list.0-in.tcl]
    set out [makeFile "" regress.list.0-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {#fde9e9}

test regress.list.1 {whole list value preserved (leading '#' first elem)} -body {
    # Tcl canonically braces a leading-'#' first element (comment-safety); the
    # tbcx round-trip must reproduce that exact string rep, as `source` does.
    set in  [makeFile {return [list "#fde9e9" "#641e1e" "#c0392b"]} regress.list.1-in.tcl]
    set out [makeFile "" regress.list.1-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{#fde9e9} #641e1e #c0392b}

test regress.list.2 {first element leading space round-trips} -body {
    set in  [makeFile {return [lindex [list " aa" "bb"] 0]} regress.list.2-in.tcl]
    set out [makeFile "" regress.list.2-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result { aa}

test regress.list.3 {first element with embedded braces round-trips} -body {
    set in  [makeFile {return [lindex [list "{x}" "bb"] 0]} regress.list.3-in.tcl]
    set out [makeFile "" regress.list.3-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{x}}

test regress.list.4 {genuine nested list of doubles still element-wise faithful} -body {
    set in  [makeFile {return [list [list 1.5 2.5] [list 3.5 4.5]]} regress.list.4-in.tcl]
    set out [makeFile "" regress.list.4-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{1.5 2.5} {3.5 4.5}}

test regress.list.5 {list whose '#' is not first is unaffected} -body {
    set in  [makeFile {return [list "bb" "#aa"]} regress.list.5-in.tcl]
    set out [makeFile "" regress.list.5-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {bb #aa}

# Lambda-misdetection variant of R2: a genuine 2-element DATA list whose first
# element needs list-quoting AND whose second element looks script-like was
# mis-serialized as a lambda, re-quoting the first element ("#a" -> "{{#a}}").
test regress.list.6 {lambda-shaped data list, leading '#' first elem, lindex} -body {
    set in  [makeFile {return [lindex [list "#a" "set x 1; puts hi"] 0]} regress.list.6-in.tcl]
    set out [makeFile "" regress.list.6-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {#a}

test regress.list.7 {lambda-shaped data list value preserved} -body {
    set in  [makeFile {return [list "#a" "set x 1; puts hi"]} regress.list.7-in.tcl]
    set out [makeFile "" regress.list.7-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{#a} {set x 1; puts hi}}

test regress.list.8 {lambda-shaped data list, leading-space first elem} -body {
    set in  [makeFile {return [lindex [list " a" "incr n; set y 2"] 0]} regress.list.8-in.tcl]
    set out [makeFile "" regress.list.8-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result { a}

test regress.list.9 {genuine lambda still precompiles and executes} -body {
    set in  [makeFile {return [apply {{a b} {expr {$a + $b}}} 3 4]} regress.list.9-in.tcl]
    set out [makeFile "" regress.list.9-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 7

# 3-element lambda-shaped DATA list whose 3rd token is a NON-ABSOLUTE namespace.
# Mis-serialized as LAMBDA_BC it makes the *whole file* fail to load
# ("lambda namespace must be absolute") — the round-trip faithfulness guard must
# reject any 3rd token that ReadLit_LambdaBC would not accept verbatim.
test regress.list.10 {3-elem data list, non-absolute 3rd token, loads} -body {
    set in  [makeFile {return [list {x} {do; it} "relative"]} regress.list.10-in.tcl]
    set out [makeFile "" regress.list.10-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {x {do; it} relative}

test regress.list.11 {3-elem data list, leading-'#' 3rd token, loads} -body {
    set in  [makeFile {return [list {x} {do; it} "#ns"]} regress.list.11-in.tcl]
    set out [makeFile "" regress.list.11-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {x {do; it} #ns}

test regress.list.12 {3-elem data list, empty 3rd token, loads} -body {
    set in  [makeFile {return [list {x} {do; it} ""]} regress.list.12-in.tcl]
    set out [makeFile "" regress.list.12-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {x {do; it} {}}

# 3rd token exactly "::" — the loader collapses a global-namespace lambda to a
# 2-element value, silently dropping the 3rd element.  Must round-trip verbatim.
test regress.list.13 {3-elem data list, "::" 3rd token preserved} -body {
    set in  [makeFile {return [list {x} {do; it} "::"]} regress.list.13-in.tcl]
    set out [makeFile "" regress.list.13-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {x {do; it} ::}

# Counter-test: a genuine 3-element lambda with an ABSOLUTE namespace must STILL
# serialize as LAMBDA_BC and execute (no over-correction).
test regress.list.14 {genuine 3-elem lambda, absolute ns, executes} -body {
    set in  [makeFile {
        namespace eval ::regns { variable v 100 }
        return [apply {{x} {expr {$x + $::regns::v}} ::regns} 5]
    } regress.list.14-in.tcl]
    set out [makeFile "" regress.list.14-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 105

# Lambda-shaped DATA list whose arg has a DEFAULT with non-canonical bracing.
# The codec writes defaults as separate literals and re-canonicalises {name
# default} on load, so a quote-braced default ("x y") was silently re-quoted
# ({x y}).  The faithfulness check must mirror the name+default split.
test regress.list.15 {lambda-shaped data list, quote-braced arg default preserved} -body {
    set in  [makeFile {return [list {{a "x y"}} {set z 1; puts $a}]} regress.list.15-in.tcl]
    set out [makeFile "" regress.list.15-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {{{a "x y"}} {set z 1; puts $a}}

# Counter-test: a genuine lambda WITH a default still serializes/executes.
test regress.list.16 {genuine lambda with arg default executes} -body {
    set in  [makeFile {return [apply {{a {b 5}} {expr {$a + $b}}} 10]} regress.list.16-in.tcl]
    set out [makeFile "" regress.list.16-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 15

# ---------------------------------------------------------------------------
# B. TclOO in-body `export` visibility
# ---------------------------------------------------------------------------

test regress.export.0 {in-body export of PascalCase method survives (external dispatch)} -body {
    set in  [makeFile {
        oo::class create ::Reg0 { method Bar {} {return ok}; export Bar }
        set o [::Reg0 new]
        return [$o Bar]
    } regress.export.0-in.tcl]
    set out [makeFile "" regress.export.0-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result ok

test regress.export.1 {in-body export shows in exported method list} -body {
    set in  [makeFile {
        oo::class create ::Reg1 { method Bar {} {return ok}; export Bar }
        return [expr {"Bar" in [info class methods ::Reg1 -all]}]
    } regress.export.1-in.tcl]
    set out [makeFile "" regress.export.1-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 1

test regress.export.2 {oo::define braced-body export survives} -body {
    set in  [makeFile {
        oo::class create ::Reg2 { method Bar {} {return ok} }
        oo::define ::Reg2 { export Bar }
        return [expr {"Bar" in [info class methods ::Reg2 -all]}]
    } regress.export.2-in.tcl]
    set out [makeFile "" regress.export.2-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result 1

test regress.export.3 {in-body unexport of lowercase method still privatises} -body {
    set in  [makeFile {
        oo::class create ::Reg3 { method lo {} {return ok}; unexport lo }
        return [list [expr {"lo" in [info class methods ::Reg3 -all]}] \
                     [expr {"lo" in [info class methods ::Reg3 -all -private]}]]
    } regress.export.3-in.tcl]
    set out [makeFile "" regress.export.3-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {0 1}

test regress.export.4 {lowercase methods stay public (no over-correction)} -body {
    set in  [makeFile {
        oo::class create ::Reg4 { method lo {} {return ok}; method Cb {} {return cb}; export Cb }
        set o [::Reg4 new]
        return [list [$o lo] [$o Cb]]
    } regress.export.4-in.tcl]
    set out [makeFile "" regress.export.4-out.tbcx]
    tbcx::save $in $out
    tbcx::load $out
} -result {ok cb}

# ---------------------------------------------------------------------------
# C. Top-level compiled at GLOBAL scope (no borrowed caller-frame locals).
#    `tbcx::save` is frequently invoked from inside a proc (tcltest bodies and
#    every save wrapper are procs).  Tcl decides whether `catch … e` / `set v …`
#    may use compiled LOCALS via EnvHasLVT = (env->procPtr ||
#    iPtr->varFramePtr->localCachePtr) — so a caller frame carrying a LocalCache
#    made the saved script's TOP LEVEL compile to that proc's local slots
#    (storeScalar/loadScalar %vN).  A serialized top-level carries no locals
#    (numLocals=0), so those instructions indexed a non-existent local array and
#    SIGSEGV'd at load.  The saver now hides the caller frame's LocalCache (and
#    compiledProcPtr) for the top-level compile.
# ---------------------------------------------------------------------------
# saveInProc: call tbcx::save from a frame that carries a LocalCache (this proc
# has many compiled local variables, accessed so the cache is materialised) —
# that is what made the saved top-level borrow proc-local slots.
proc saveInProc {in out} {
    set g0 0; set g1 1; set g2 2; set g3 3; set g4 4
    set g5 5; set g6 6; set g7 7; set g8 8; set g9 9
    incr g0 $g9; incr g1 $g8; incr g2 $g7
    tbcx::save $in $out
}
# loadFresh: load at GLOBAL scope in a fresh interp (where a corrupt top-level
# referencing local slot N would index a non-existent local array and crash).
proc loadFresh {out} {
    set i [interp create]
    try {
        $i eval {package require tbcx}
        return [$i eval [list tbcx::load $out]]
    } finally {
        interp delete $i
    }
}

test regress.toplevel.catch.var {top-level catch+var (after OO defs) saved from a proc loads at global scope} -body {
    set in  [makeFile {oo::class create ::Tlc { method Up {} { return u } }
set o [::Tlc new]
list [catch {$o Up} e] $e} regress.tlcv-in.tcl]
    set out [makeFile "" regress.tlcv-out.tbcx]
    saveInProc $in $out
    loadFresh $out
} -result {1 {unknown method "Up": must be destroy}}

test regress.toplevel.catch.options {top-level catch+result var (plain script) saved from a proc} -body {
    set in  [makeFile {set x [catch {error boom} e]; list $x $e} regress.tlco-in.tcl]
    set out [makeFile "" regress.tlco-out.tbcx]
    saveInProc $in $out
    loadFresh $out
} -result {1 boom}

cleanupTests
